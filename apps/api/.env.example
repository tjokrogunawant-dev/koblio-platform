# Auth0 Configuration
AUTH0_ISSUER_URL=https://YOUR_TENANT.auth0.com/
AUTH0_AUDIENCE=https://api.koblio.com
AUTH0_CLIENT_ID=YOUR_CLIENT_ID
AUTH0_ROLES_NAMESPACE=https://koblio.com/roles

# Internal JWT (student login — must be at least 32 chars)
JWT_SECRET=your-secret-here-min-32-chars-change-in-prod

# Database
DATABASE_URL=postgresql://koblio:koblio_dev@localhost:5432/koblio_dev?schema=public

# Server
PORT=3001

# Sentry
SENTRY_DSN=
