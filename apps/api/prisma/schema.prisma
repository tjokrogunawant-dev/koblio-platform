generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  PARENT
  TEACHER
  ADMIN
}

enum SchoolRole {
  TEACHER
  SCHOOL_ADMIN
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  auth0Id     String   @unique @map("auth0_id")
  email       String?  @unique
  role        UserRole
  displayName String   @map("display_name")
  username      String?  @unique
  passwordHash  String?  @map("password_hash")
  grade         Int?
  country     String?
  locale      String?
  avatarId    String?  @map("avatar_id")
  avatarSlug  String?  @map("avatar_slug")
  xp            Int      @default(0)
  level         Int      @default(1)
  streakCount   Int      @default(0) @map("streak_count")
  lastActiveDate DateTime? @map("last_active_date")
  coins         Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parentLinks           ParentChildLink[]       @relation("ParentUser")
  childLinks            ParentChildLink[]       @relation("ChildUser")
  consentsGiven         ParentalConsent[]       @relation("ConsentParent")
  consentsReceived      ParentalConsent[]       @relation("ConsentChild")
  schoolTeachers        SchoolTeacher[]
  classroomsOwned       Classroom[]
  enrollments           Enrollment[]
  attempts              StudentProblemAttempt[]
  pointsLedger          PointsLedger[]
  assignmentsCreated    Assignment[]            @relation("TeacherAssignments")
  assignmentSubmissions AssignmentSubmission[]  @relation("StudentSubmissions")
  badges                Badge[]

  @@map("users")
}

model School {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  country   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teachers   SchoolTeacher[]
  classrooms Classroom[]

  @@map("schools")
}

model SchoolTeacher {
  id        String     @id @default(uuid()) @db.Uuid
  teacherId String     @map("teacher_id") @db.Uuid
  schoolId  String     @map("school_id") @db.Uuid
  role      SchoolRole @default(TEACHER)
  joinedAt  DateTime   @default(now()) @map("joined_at")

  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([teacherId, schoolId])
  @@map("school_teachers")
}

model Classroom {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  grade     Int
  classCode String   @unique @map("class_code")
  teacherId String   @map("teacher_id") @db.Uuid
  schoolId  String?  @map("school_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teacher     User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school      School?      @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  enrollments Enrollment[]
  assignments Assignment[]

  @@map("classrooms")
}

model Enrollment {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  classroomId String   @map("classroom_id") @db.Uuid
  enrolledAt  DateTime @default(now()) @map("enrolled_at")

  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([studentId, classroomId])
  @@map("enrollments")
}

model ParentChildLink {
  id        String   @id @default(uuid()) @db.Uuid
  parentId  String   @map("parent_id") @db.Uuid
  childId   String   @map("child_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  parent User @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("ChildUser", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@map("parent_child_links")
}

model ParentalConsent {
  id             String   @id @default(uuid()) @db.Uuid
  parentId       String   @map("parent_id") @db.Uuid
  childId        String   @map("child_id") @db.Uuid
  accepted       Boolean
  consentVersion String   @map("consent_version")
  ipAddress      String   @map("ip_address")
  timestamp      DateTime
  createdAt      DateTime @default(now()) @map("created_at")

  parent User @relation("ConsentParent", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("ConsentChild", fields: [childId], references: [id], onDelete: Cascade)

  @@map("parental_consents")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemType {
  MCQ
  FILL_BLANK
  TRUE_FALSE
}

enum Curriculum {
  US_COMMON_CORE
}

model Problem {
  id         String      @id @default(uuid()) @db.Uuid
  curriculum Curriculum  @default(US_COMMON_CORE)
  grade      Int
  strand     String
  topic      String
  difficulty Difficulty
  type       ProblemType
  content    Json
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  attempts             StudentProblemAttempt[]
  assignmentSubmissions AssignmentSubmission[]

  @@index([grade, strand, topic])
  @@index([difficulty])
  @@map("problems")
}

model StudentProblemAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  problemId   String   @map("problem_id") @db.Uuid
  answer      String
  correct     Boolean
  timeSpentMs Int      @map("time_spent_ms")
  hintUsed    Boolean  @default(false) @map("hint_used")
  createdAt   DateTime @default(now()) @map("created_at")

  student              User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  problem              Problem                @relation(fields: [problemId], references: [id], onDelete: Cascade)
  assignmentSubmissions AssignmentSubmission[]

  @@index([studentId, problemId])
  @@index([studentId, createdAt])
  @@map("student_problem_attempts")
}

model PointsLedger {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  amount      Int
  reason      String
  attemptId   String?  @map("attempt_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@map("points_ledger")
}

model Assignment {
  id          String     @id @default(uuid()) @db.Uuid
  classroomId String     @map("classroom_id") @db.Uuid
  teacherId   String     @map("teacher_id") @db.Uuid
  title       String
  topic       String
  strand      String
  grade       Int
  difficulty  Difficulty
  problemIds  String[]   @map("problem_ids") @db.Uuid
  dueDate     DateTime?  @map("due_date")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  classroom   Classroom             @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher     User                  @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@index([classroomId])
  @@index([teacherId])
  @@map("assignments")
}

model AssignmentSubmission {
  id           String    @id @default(uuid()) @db.Uuid
  assignmentId String    @map("assignment_id") @db.Uuid
  studentId    String    @map("student_id") @db.Uuid
  problemId    String    @map("problem_id") @db.Uuid
  attemptId    String?   @map("attempt_id") @db.Uuid
  submittedAt  DateTime? @map("submitted_at")
  correct      Boolean?

  assignment Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User                   @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  problem    Problem                @relation(fields: [problemId], references: [id], onDelete: Cascade)
  attempt    StudentProblemAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)

  @@unique([assignmentId, studentId, problemId])
  @@index([studentId])
  @@map("assignment_submissions")
}

enum BadgeType {
  FIRST_CORRECT
  PERFECT_10
  STREAK_7
  STREAK_30
  PROBLEMS_100
  CORRECT_50
  FRACTION_MASTER
  SPEED_DEMON
  MATH_EXPLORER
  TOP_OF_CLASS
}

model Badge {
  id        String    @id @default(uuid()) @db.Uuid
  studentId String    @map("student_id") @db.Uuid
  type      BadgeType
  awardedAt DateTime  @default(now()) @map("awarded_at")

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, type])
  @@index([studentId])
  @@map("badges")
}
