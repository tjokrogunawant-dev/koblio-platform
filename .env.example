# Generate with: openssl rand -hex 32
JWT_SECRET=

# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# Connection strings — reference POSTGRES_PASSWORD so it's only set once above
DATABASE_URL=postgresql://koblio:${POSTGRES_PASSWORD}@localhost:5433/koblio
REDIS_URL=redis://localhost:6380

# Public URL of the API (no trailing slash)
API_URL=http://localhost:3001

# Public URL of the web app (used for CORS on the API)
WEB_URL=http://localhost:3000

# Optional — leave blank to disable
SENTRY_DSN=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@koblio.com
